'*--files=[Fichiers liés à cette tâche]:FILES:_default' \
'--optional[Marquer comme optionnelle]' \
'-h[Print help]' \
'--help[Print help]' \
':phase_id -- ID de la phase:_default' \
':name -- Nom de la tâche:_default' \
&& ret=0
;;
(done)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':task_id -- ID de la tâche (ex\: 9.1, 9.2.1):_default' \
&& ret=0
;;
(start)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':task_id -- ID de la tâche:_default' \
&& ret=0
;;
(edit)
