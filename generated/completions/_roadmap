    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_roadmap_commands" \
"*::: :->roadmap" \
&& ret=0
    case $state in
    (roadmap)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:roadmap-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--parent=[Phase parente (pour les sous-phases)]:PARENT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':id -- ID de la phase (ex\: 9, 19a):_default' \
':name -- Nom de la phase:_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'--name=[Nouveau nom]:NAME:_default' \
'--description=[Nouvelle description]:DESCRIPTION:_default' \
'-h[Print help]' \
'--help[Print help]' \
':id -- ID de la phase:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--table[Afficher en tableau formaté]' \
'--json[Sortie JSON]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(tree)
